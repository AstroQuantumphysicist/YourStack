{
  "name": "yourstack",
  "version": "0.1.0",
  "private": true,
  "description": "YourStack — Bring your own server. We turn it into a cloud.",
  "license": "Apache-2.0",
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "overrides": {
      "ioredis": "5.4.1"
    }
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "clean": "turbo run clean && rimraf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "db:generate": "pnpm --filter @yourstack/db generate",
    "db:migrate": "pnpm --filter @yourstack/db migrate:deploy",
    "db:migrate:dev": "pnpm --filter @yourstack/db migrate:dev",
    "db:seed": "pnpm --filter @yourstack/db seed",
    "db:studio": "pnpm --filter @yourstack/db studio",
    "docker:up": "docker compose -f infra/docker-compose.yml up -d",
    "docker:down": "docker compose -f infra/docker-compose.yml down",
    "docker:logs": "docker compose -f infra/docker-compose.yml logs -f"
  },
  "devDependencies": {
    "@eslint/js": "^9.11.0",
    "@types/node": "^20.14.0",
    "eslint": "^9.11.0",
    "prettier": "^3.3.3",
    "rimraf": "^6.0.1",
    "turbo": "^2.1.3",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.7.0",
    "vitest": "^2.1.1"
  }
}
