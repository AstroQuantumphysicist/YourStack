# ============================================================================
# NodeRail Web Dashboard — environment
# Copy to .env.local for local development.
# ============================================================================

# Base URL of the NodeRail control-plane API (Fastify). All routes live under /v1.
# The browser talks to this directly (cookie session, credentials: 'include').
NEXT_PUBLIC_API_URL=http://localhost:4000

# Port the Next.js server binds to (used by `next start`). Defaults to 3000.
PORT=3000

# ----------------------------------------------------------------------------
# Cookie / auth note:
#   Local dev (web :3000 -> api :4000) is same-site, so the API's Lax session
#   cookie is sent automatically with credentials: 'include'.
#   In PRODUCTION the api and web must share a registrable domain
#   (e.g. app.noderail.com + api.noderail.com) and the API must set
#   SESSION_COOKIE_DOMAIN=.noderail.com so the cookie is shared.
# ----------------------------------------------------------------------------
