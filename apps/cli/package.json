{
  "name": "@noderail/cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "noderail — the NodeRail developer CLI.",
  "main": "dist/index.js",
  "bin": {
    "noderail": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --max-warnings 0",
    "test": "vitest run",
    "clean": "rimraf dist .turbo"
  },
  "dependencies": {
    "@clack/prompts": "^0.7.0",
    "@noderail/shared": "workspace:*",
    "commander": "^12.1.0",
    "picocolors": "^1.1.0",
    "yaml": "^2.5.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  }
}
