# NodeRail agent configuration.
#
# On Linux this file lives at /etc/noderail/agent.toml and is owned by the
# `noderail` user with 0600 permissions (it holds secrets). The `register`
# subcommand writes node_id / agent_token / command_verify_key for you, so you
# normally only need to set api_url before registering.

# Base URL of the control-plane API.
api_url = "https://api.noderail.dev"

# Populated automatically by `noderail-agent register` — leave blank initially.
node_id = ""
agent_token = ""
command_verify_key = ""

# Optional region label for this node.
# region = "us-east"

# Working directory for git clones, build contexts, and generated Caddyfiles.
data_dir = "/var/lib/noderail"

# Optional free-form labels.
[labels]
# tier = "edge"
