  "dependencies": {
    "@noderail/config": "workspace:*",
    "@noderail/db": "workspace:*",
    "@noderail/security": "workspace:*",
    "@noderail/shared": "workspace:*",
    "@prisma/client": "^5.20.0",
    "bullmq": "^5.13.2",
    "ioredis": "5.4.1",
    "pino": "^9.4.0",
    "undici": "^6.19.8",
    "yaml": "^2.5.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "pino-pretty": "^11.2.2",
    "tsup": "^8.3.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  }
}
